{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OTel Triage Profile",
  "description": "Defines a named triage profile with optional repo-specific config and/or per-issue evaluation criteria. Profiles are composable — multiple profiles can be merged in order.",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name shown in reports."
    },
    "description": {
      "type": "string",
      "description": "One-line summary of what this profile configures."
    },
    "repo": {
      "type": "object",
      "description": "Repo-specific configuration. Replaces hardcoded OTEL_WEBSITE behavior.",
      "additionalProperties": false,
      "properties": {
        "default_repo": {
          "type": "string",
          "description": "Default repository (owner/repo) when --repo is omitted.",
          "pattern": "^[^/]+/[^/]+$",
          "examples": ["open-telemetry/opentelemetry.io"]
        },
        "auto_apply_for": {
          "type": "array",
          "description": "Repos that trigger automatic application of this profile (owner/repo format).",
          "items": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
          "examples": [["open-telemetry/opentelemetry.io"]]
        },
        "sig_keywords": {
          "type": "array",
          "description": "Keyword → SIG label mapping for content inference on unlabeled issues.",
          "items": {
            "type": "object",
            "required": ["keywords", "label"],
            "additionalProperties": false,
            "properties": {
              "keywords": {
                "type": "array",
                "description": "Terms to search for in issue title and body.",
                "items": { "type": "string" },
                "minItems": 1
              },
              "label": {
                "type": "string",
                "description": "The sig:* label to assign when a keyword matches.",
                "examples": ["sig:go", "sig:collector"]
              }
            }
          }
        },
        "type_filters": {
          "type": "array",
          "description": "Mapping from --type flag value to title prefix for client-side filtering.",
          "items": {
            "type": "object",
            "required": ["type", "title_prefix"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "description": "Value passed via --type flag.",
                "examples": ["docs", "bug", "feat", "blog", "feedback"]
              },
              "title_prefix": {
                "type": "string",
                "description": "Title prefix to match (case-insensitive substring).",
                "examples": [
                  "[Docs]:",
                  "bug:",
                  "feat:",
                  "blog:",
                  "page feedback:"
                ]
              },
              "label_match": {
                "type": "string",
                "description": "Optional: also match issues with this label (OR with title_prefix).",
                "examples": ["page feedback"]
              }
            }
          }
        },
        "category_buckets": {
          "type": "array",
          "description": "Named category buckets used when grouping issues for parallel subagent analysis.",
          "items": { "type": "string" },
          "examples": [
            [
              "sig:collector",
              "sig:go",
              "docs-general",
              "blog",
              "registry",
              "ci-infra",
              "feedback",
              "uncategorized"
            ]
          ]
        },
        "label_taxonomy": {
          "type": "object",
          "description": "Labels that exist in this repo, grouped by category. Used for label suggestions.",
          "additionalProperties": false,
          "properties": {
            "area": { "type": "array", "items": { "type": "string" } },
            "sig": { "type": "array", "items": { "type": "string" } },
            "localization": { "type": "array", "items": { "type": "string" } },
            "effort": { "type": "array", "items": { "type": "string" } },
            "priority": { "type": "array", "items": { "type": "string" } },
            "triage": { "type": "array", "items": { "type": "string" } },
            "type": { "type": "array", "items": { "type": "string" } }
          }
        },
        "comment_templates": {
          "type": "object",
          "description": "Pre-written comment templates for common triage actions.",
          "additionalProperties": false,
          "properties": {
            "stale": { "type": "string" },
            "needs_info": { "type": "string" },
            "duplicate": { "type": "string" },
            "accepted": { "type": "string" },
            "good_first_issue": { "type": "string" }
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "description": "Per-issue evaluation layer. Adds a Profile Assessment block to each dossier.",
      "required": ["report_note", "criteria", "verdict_labels"],
      "additionalProperties": false,
      "properties": {
        "report_note": {
          "type": "string",
          "description": "Contextual note shown at the top of the Profile Assessment section in the report."
        },
        "criteria": {
          "type": "array",
          "description": "Evaluation questions the triager answers per issue.",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["label", "question", "weight"],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string",
                "description": "Short label shown in the assessment table.",
                "examples": ["Scope", "Ramp-up", "Effort estimate"]
              },
              "question": {
                "type": "string",
                "description": "What the triager should assess for this criterion."
              },
              "weight": {
                "type": "string",
                "enum": ["high", "medium", "low"],
                "description": "Influences overall verdict: high-weight failures → not_suitable, mixed high-weight → maybe."
              }
            }
          }
        },
        "verdict_labels": {
          "type": "object",
          "description": "GitHub labels to suggest per verdict in the dossier's label command.",
          "required": ["recommended", "maybe", "not_suitable"],
          "additionalProperties": false,
          "properties": {
            "recommended": {
              "type": "string",
              "examples": ["mentorship:bloomberg"]
            },
            "maybe": {
              "type": "string"
            },
            "not_suitable": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
