# ------------------------------------------------------------
# Localization teams own their locale's files.
# ------------------------------------------------------------
# NOTE: .github/scripts/pr-approval-labels.sh reads the `/content/<loc>/`
# directory rules below to apply the `missing:sig-approval` label on locale
# PRs. Keep them as plain directory rules: rewriting one as a glob (e.g.
# `/content/ja/**`) silently stops the labeler from matching that locale.
#
# The configuration below is generated by the following code:
#
# ```js
# import fs from 'node:fs';
# const log = (line) => console.log(line);
# const locales = ['bn', 'es', 'fr', 'ja', 'pl', 'pt', 'ro', 'uk', 'zh'];
# locales.sort();
# for (const loc of locales) {
#   const approver = `@open-telemetry/docs-${loc}-approvers`;
#   log(`\n# ${loc}`);
#   log(`/.cspell/${loc}-*.txt ${approver}`);
#   // Keep `/content/<loc>/` a plain directory rule: pr-approval-labels.sh
#   // parses it for the missing:sig-approval label (no glob form).
#   log(`/content/${loc}/      ${approver}`);
#   const prhYml = `prh/${loc}.yml`;
#   if (fs.existsSync(prhYml)) {
#     log(`/${prhYml}       ${approver}`);
#   }
# }
# ```

# bn
/.cspell/bn-*.txt @open-telemetry/docs-bn-approvers
/content/bn/      @open-telemetry/docs-bn-approvers

# es
/.cspell/es-*.txt @open-telemetry/docs-es-approvers
/content/es/      @open-telemetry/docs-es-approvers

# fr
/.cspell/fr-*.txt @open-telemetry/docs-fr-approvers
/content/fr/      @open-telemetry/docs-fr-approvers

# ja
/.cspell/ja-*.txt @open-telemetry/docs-ja-approvers
/content/ja/      @open-telemetry/docs-ja-approvers
/prh/ja.yml       @open-telemetry/docs-ja-approvers

# pl
/.cspell/pl-*.txt @open-telemetry/docs-pl-approvers
/content/pl/      @open-telemetry/docs-pl-approvers

# pt
/.cspell/pt-*.txt @open-telemetry/docs-pt-approvers
/content/pt/      @open-telemetry/docs-pt-approvers

# ro
/.cspell/ro-*.txt @open-telemetry/docs-ro-approvers
/content/ro/      @open-telemetry/docs-ro-approvers

